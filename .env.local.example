# Supabase (대시보드 → Project Settings → API)
# Project URL 을 그대로 복사합니다.
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co

# anon / public 키 (클라이언트에 노출됩니다. RLS 로 보호하세요.)
# Vercel 환경 변수 길이 제한 대비: 대시보드 API 의 publishable 키(sb_publishable_...) 사용 가능.
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_uu2Pn8yfrXL3_bgStYHR6A_QxEuymyU

# OAuth(구글·카카오) 사용 시 Supabase 대시보드 → Authentication → URL Configuration 에서
# Redirect URLs 에 아래를 추가하세요 (로컬·배포 도메인 각각).
#   http://localhost:3000/auth/callback
#   https://your-domain.com/auth/callback

# --- WebRTC TURN (선택, 밖 네트워크·모바일 LTE 등에서 라이브 연결 안 될 때) ---
# STUN만으로는 대칭 NAT 등에서 P2P가 실패할 수 있음. Metered/Twilio/coturn 등에서 TURN 발급 후 설정.
# 세 값을 모두 넣어야 클라이언트 ICE 목록에 TURN이 붙습니다.
# URL은 쉼표로 여러 개 (UDP turn + TCP/TLS turns 권장).
# NEXT_PUBLIC_WEBRTC_TURN_URLS=turn:xxx:3478,turns:xxx:5349
# NEXT_PUBLIC_WEBRTC_TURN_USERNAME=
# NEXT_PUBLIC_WEBRTC_TURN_CREDENTIAL=
