# Supabase (대시보드 → Project Settings → API)
# Project URL 을 그대로 복사합니다.
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co

# anon / public 키 (클라이언트에 노출됩니다. RLS 로 보호하세요.)
# Vercel 환경 변수 길이 제한 대비: 대시보드 API 의 publishable 키(sb_publishable_...) 사용 가능.
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_uu2Pn8yfrXL3_bgStYHR6A_QxEuymyU

# OAuth(구글·카카오) 사용 시 Supabase 대시보드 → Authentication → URL Configuration 에서
# Redirect URLs 에 아래를 추가하세요 (로컬·배포 도메인 각각).
#   http://localhost:3000/auth/callback
#   https://your-domain.com/auth/callback

# =============================================================================
# WebRTC TURN (권장: 모바일 LTE·대칭 NAT 에서 iceConnectionState 가 failed 일 때)
# =============================================================================
# 구조 — 아래 세 변수가 모두 있어야 `RTCPeerConnection` ICE 목록에 TURN(릴레이)이 추가됩니다.
#   NEXT_PUBLIC_WEBRTC_TURN_URLS     — 쉼표로 구분한 turn:/turns: URL (따옴표로 전체를 감싸도 됨)
#   NEXT_PUBLIC_WEBRTC_TURN_USERNAME — TURN 인증 사용자명
#   NEXT_PUBLIC_WEBRTC_TURN_CREDENTIAL — TURN 인증 비밀번호
#
# NEXT_PUBLIC_* 는 빌드 시점에 클라이언트 번들에 박힙니다.
# Vercel 사용 시: Project → Settings → Environment Variables 에 넣은 뒤 재배포해야 반영됩니다.
#
# --- 테스트·개발용 무료 TURN 예시 (직접 발급한 값으로 교체 — 저장소에 실제 비밀번호 커밋 금지) ---
#
# [Metered.ca 무료 티어]
#   1) https://www.metered.ca/ 가입 후 TURN / STUN 대시보드에서 앱 생성
#   2) 제시되는 relay 호스트(예: xxx.relay.metered.ca), 포트, username, credential 복사
#   3) UDP + TCP + TLS 조합 권장 (일부 통신사·Wi-Fi 는 UDP 만 막는 경우가 있음). 예:
#        turn:YOUR_ID.relay.metered.ca:80
#        turn:YOUR_ID.relay.metered.ca:443?transport=tcp
#        turns:YOUR_ID.relay.metered.ca:443?transport=tcp
#
# [Twilio Network Traversal Service]
#   Twilio 콘솔에서 ICE 서버용 사용자명/비밀번호 발급 후 동일 형식으로 설정
#
# [자체 coturn]
#   VPS 에 coturn 설치 후 turn:your-domain:3478, turns:your-domain:5349 등을 등록
#
# 완전히 고정된 “공개 무료 TURN” 은 보안·악용 때문에 거의 없으며, 무료 티어도 계정 발급이 일반적입니다.
#
# NEXT_PUBLIC_WEBRTC_TURN_URLS=turn:example.relay.metered.ca:80,turn:example.relay.metered.ca:443?transport=tcp,turns:example.relay.metered.ca:443?transport=tcp
# NEXT_PUBLIC_WEBRTC_TURN_USERNAME=your-metered-username
# NEXT_PUBLIC_WEBRTC_TURN_CREDENTIAL=your-metered-credential
